{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "uid": "platform-overview",
  "title": "Platform Overview — study-platform",
  "description": "High-level health dashboard for the study-platform service mesh. Shows request rate, error rate, latency, pod count, ArgoCD sync status, and node resource utilization.",
  "tags": ["study-platform", "overview", "sre", "istio"],
  "style": "dark",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "1h", "3h", "6h", "12h", "24h", "2d", "7d"]
  },
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "title": "SLO / Error Budget",
      "url": "/d/platform-slo/slo-error-budget",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Istio Mesh",
      "url": "/d/istio-mesh/istio-mesh",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "ArgoCD",
      "url": "/d/argocd/argocd",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(up, cluster)",
        "current": {},
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(kube_pod_info{cluster=~\"$cluster\"}, namespace)",
        "current": {},
        "multi": false,
        "includeAll": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": "${DS_PROMETHEUS}",
        "expr": "changes(kube_deployment_status_observed_generation{namespace=\"$namespace\", cluster=~\"$cluster\"}[2m]) > 0",
        "step": "60s",
        "titleFormat": "Deployment change",
        "textFormat": "{{ deployment }} updated",
        "hide": false,
        "enable": true,
        "type": "alert"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "description": "Total inbound requests per second across all services in the namespace, via Istio telemetry.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (destination_service_name) (\n  rate(istio_requests_total{\n    destination_service_namespace=~\"$namespace\",\n    cluster=~\"$cluster\"\n  }[5m])\n)",
          "legendFormat": "{{ destination_service_name }}",
          "refId": "A",
          "interval": "30s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "description": "Percentage of 5xx responses across all services in the namespace.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 0.05,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "orange", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "text": { "valueSize": 32 }
      },
      "targets": [
        {
          "expr": "sum(rate(istio_requests_total{response_code=~\"5.*\", destination_service_namespace=~\"$namespace\", cluster=~\"$cluster\"}[5m]))\n/\nsum(rate(istio_requests_total{destination_service_namespace=~\"$namespace\", cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "SLO Status",
      "description": "Current SLO compliance: green = within budget, red = budget burned.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0.98,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "valueSize": 28 },
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "1 - slo:error_rate:ratio_rate5m",
          "legendFormat": "Availability",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "p95 Latency (ms)",
      "description": "95th percentile request latency in milliseconds. SLO target: 500ms.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50,\n  sum by (le, destination_service_name) (\n    rate(istio_request_duration_milliseconds_bucket{\n      destination_service_namespace=~\"$namespace\",\n      cluster=~\"$cluster\"\n    }[5m])\n  )\n)",
          "legendFormat": "p50 — {{ destination_service_name }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95,\n  sum by (le, destination_service_name) (\n    rate(istio_request_duration_milliseconds_bucket{\n      destination_service_namespace=~\"$namespace\",\n      cluster=~\"$cluster\"\n    }[5m])\n  )\n)",
          "legendFormat": "p95 — {{ destination_service_name }}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99,\n  sum by (le, destination_service_name) (\n    rate(istio_request_duration_milliseconds_bucket{\n      destination_service_namespace=~\"$namespace\",\n      cluster=~\"$cluster\"\n    }[5m])\n  )\n)",
          "legendFormat": "p99 — {{ destination_service_name }}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Pods per Deployment",
      "description": "Number of ready pods per deployment in the namespace. Shows scaling events.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "always",
            "pointSize": 4,
            "spanNulls": false
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "min", "max"]
        }
      },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{\n  namespace=~\"$namespace\",\n  cluster=~\"$cluster\"\n}",
          "legendFormat": "{{ deployment }} (ready)",
          "refId": "A"
        },
        {
          "expr": "kube_deployment_spec_replicas{\n  namespace=~\"$namespace\",\n  cluster=~\"$cluster\"\n}",
          "legendFormat": "{{ deployment }} (desired)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "ArgoCD Application Sync Status",
      "description": "Current sync and health status of all ArgoCD applications targeting the selected cluster.",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sync_status" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Synced": { "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "OutOfSync": { "color": "red", "index": 1 } } },
                  { "type": "value", "options": { "Unknown": { "color": "gray", "index": 2 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "health_status" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Healthy": { "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "Degraded": { "color": "red", "index": 1 } } },
                  { "type": "value", "options": { "Progressing": { "color": "yellow", "index": 2 } } },
                  { "type": "value", "options": { "Missing": { "color": "gray", "index": 3 } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "sync_status", "desc": true }],
        "footer": { "show": false, "reducer": ["sum"] }
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "rows",
            "valueLabel": "__value__"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["name", "project", "dest_server", "sync_status", "health_status", "repo"]
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "argocd_app_info",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "title": "Node CPU Utilization",
      "description": "CPU utilization per node. Alert threshold: 80% for 30 minutes.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }
      },
      "targets": [
        {
          "expr": "node:cpu_utilization:ratio",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Node Memory Utilization",
      "description": "Memory utilization per node. Alert threshold: 90% for 10 minutes.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "orange", "value": 0.85 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }
      },
      "targets": [
        {
          "expr": "node:memory_utilization:ratio",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Active Firing Alerts",
      "description": "Currently firing ALERTS from Prometheus. Filtered to study-platform team.",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "P1": { "color": "red", "index": 0 } } },
                  { "type": "value", "options": { "P2": { "color": "orange", "index": 1 } } },
                  { "type": "value", "options": { "P3": { "color": "gray", "index": 2 } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "severity", "desc": false }]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "rows" } },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "names": ["alertname", "severity", "cluster", "namespace", "component", "summary"] }
          }
        }
      ],
      "targets": [
        {
          "expr": "ALERTS{team=\"sre\", alertstate=\"firing\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ]
}
